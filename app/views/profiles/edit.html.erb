<h2>プロフィール編集</h2>

<%= form_with model: @user, url: user_path(@user), method: :patch, local: true, class: "profile-edit" do |f|%>
  <div>
    <%= f.label :avatar, "プロフィール画像" %><br>
    <%= f.file_field :avatar, accept: "image/*" %>
  </div>

  <div>
    <%= f.label :name, "名前" %><br>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :introduction, "自己紹介" %><br>
    <%= f.text_area :introduction %>
  </div>

  <div>
    <%= f.submit "更新", class: "pro-button" %>
  </div>
<% end %>

<%= link_to "戻る", user_path(@user), class: "btn btn-secondary"%>